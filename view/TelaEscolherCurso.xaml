<UserControl x:Class="Learnix.TelaEscolherCurso"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Learnix"
             Background="#1E1E1E">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#2A2040"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#4E3A7A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#3A2860"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="borda" Property="Background" Value="#1B5E20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:SidebarInstrutor x:Name="Sidebar" Grid.Column="0"/>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,32,36,32">

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="&#x1F4DA;  Escolher Curso"
                                   Foreground="White" FontSize="24" FontWeight="Bold"
                                   FontFamily="Segoe UI"/>
                        <TextBlock Text="Candidate-se a um curso disponível ou crie um novo"
                                   Foreground="#9E8FC0" FontSize="12"
                                   FontFamily="Segoe UI" Margin="0,6,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="&#x2B; Adicionar Curso"
                            VerticalAlignment="Bottom"
                            Click="BtnAdicionarCurso_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#4E3A7A"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="20,10"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="borda" Background="{TemplateBinding Background}"
                                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="borda" Property="Background" Value="#3A2860"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="borda" Property="Background" Value="#2C1F4A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Formulário de novo curso (oculto por padrão) -->
                <Border x:Name="PainelNovoCurso" Visibility="Collapsed"
                        Background="#2A2040" CornerRadius="12" Padding="24,20" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="&#x1F4DD; Novo Curso"
                                   Foreground="White" FontSize="16" FontWeight="Bold"
                                   FontFamily="Segoe UI" Margin="0,0,0,16"/>

                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="TÍTULO" Foreground="#9E8FC0" FontSize="11"
                                           FontFamily="Segoe UI" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtTitulo" Background="#3A2860" Foreground="White"
                                         BorderThickness="0" Padding="12,8" FontFamily="Segoe UI" FontSize="13">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                            <ScrollViewer x:Name="PART_ContentHost"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="CATEGORIA" Foreground="#9E8FC0" FontSize="11"
                                           FontFamily="Segoe UI" Margin="0,0,0,4"/>
                                <ComboBox x:Name="ComboCategorias" Background="#3A2860" Foreground="White"
                                          BorderThickness="0" Padding="12,8" FontFamily="Segoe UI" FontSize="13"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="CARGA HORÁRIA (h)" Foreground="#9E8FC0" FontSize="11"
                                           FontFamily="Segoe UI" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtCargaHoraria" Background="#3A2860" Foreground="White"
                                         BorderThickness="0" Padding="12,8" FontFamily="Segoe UI" FontSize="13">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                            <ScrollViewer x:Name="PART_ContentHost"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="PREÇO (R$)" Foreground="#9E8FC0" FontSize="11"
                                           FontFamily="Segoe UI" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtPreco" Background="#3A2860" Foreground="White"
                                         BorderThickness="0" Padding="12,8" FontFamily="Segoe UI" FontSize="13">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                            <ScrollViewer x:Name="PART_ContentHost"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </StackPanel>
                        </UniformGrid>

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="DESCRIÇÃO" Foreground="#9E8FC0" FontSize="11"
                                       FontFamily="Segoe UI" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtDescricao" Background="#3A2860" Foreground="White"
                                     BorderThickness="0" Padding="12,8" FontFamily="Segoe UI" FontSize="13"
                                     AcceptsReturn="True" MinHeight="70" TextWrapping="Wrap">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                        <ScrollViewer x:Name="PART_ContentHost"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="AULAS DO CURSO" Foreground="#9E8FC0" FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,4"/>

                            <Border Background="#1E1E1E" CornerRadius="8" Padding="16">
                                <StackPanel>
                                    <UniformGrid Columns="3" Margin="0,0,0,12">
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="TÍTULO DA AULA" Foreground="#9E8FC0" FontSize="10" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                                            <TextBox x:Name="TxtAulaTitulo" Background="#3A2860" Foreground="White" BorderThickness="0" Padding="10,8" FontFamily="Segoe UI" FontSize="12">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="TextBox">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                        <ScrollViewer x:Name="PART_ContentHost"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="DURAÇÃO (MIN)" Foreground="#9E8FC0" FontSize="10" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                                            <TextBox x:Name="TxtAulaDuracao" Background="#3A2860" Foreground="White" BorderThickness="0" Padding="10,8" FontFamily="Segoe UI" FontSize="12">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="TextBox">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                        <ScrollViewer x:Name="PART_ContentHost"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </StackPanel>

                                        <StackPanel>
                                            <TextBlock Text="URL DO VÍDEO" Foreground="#9E8FC0" FontSize="10" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                                            <TextBox x:Name="TxtAulaUrl" Background="#3A2860" Foreground="White" BorderThickness="0" Padding="10,8" FontFamily="Segoe UI" FontSize="12">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="TextBox">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                        <ScrollViewer x:Name="PART_ContentHost"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </StackPanel>
                                    </UniformGrid>

                                    <Button Content="&#x2B; Adicionar Aula" Click="BtnAddAula_Click" HorizontalAlignment="Right">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#4E3A7A"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Padding" Value="16,8"/>
                                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="b" Property="Background" Value="#3A2860"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <ItemsControl x:Name="ListaAulasNovas" Margin="0,12,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#3A2860" CornerRadius="6" Padding="10" Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Ordem, StringFormat='{}Aula {0}: '}" Foreground="#A5D6A7" FontWeight="Bold" FontFamily="Segoe UI" FontSize="13"/>
                                                            <TextBlock Text="{Binding Titulo}" Foreground="White" FontFamily="Segoe UI" FontSize="13" Margin="4,0,0,0"/>
                                                            <TextBlock Text="{Binding Duracao, StringFormat='{} ({0} min)'}" Foreground="#9E8FC0" FontFamily="Segoe UI" FontSize="12" VerticalAlignment="Bottom" Margin="8,0,0,1"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Content="&#x2715;" Background="Transparent" Foreground="#EF9A9A" BorderThickness="0" Cursor="Hand" Click="BtnRemoverAula_Click" Tag="{Binding IdTemp}" FontSize="14" FontWeight="Bold">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" Background="{TemplateBinding Background}" />
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancelar" Click="BtnCancelarNovoCurso_Click"
                                    Margin="0,0,10,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#3A2060"/>
                                        <Setter Property="Foreground" Value="#D8CCF0"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="20,10"/>
                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="&#x1F4BE; Salvar Curso" Click="BtnSalvarNovoCurso_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#2E7D32"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="20,10"/>
                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="b" Property="Background" Value="#1B5E20"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="PainelVazio" Visibility="Collapsed"
                        Style="{StaticResource CardStyle}">
                    <TextBlock Text="Nenhum curso disponível no momento."
                               Foreground="#9E8FC0" FontSize="13" FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                </Border>

                <ItemsControl x:Name="ListaCursos">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <Border Background="{Binding CorCategoria}" CornerRadius="20"
                                                    Padding="10,4" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding NomeCategoria}"
                                                           Foreground="{Binding CorTextoCategoria}"
                                                           FontFamily="Segoe UI" FontSize="11"/>
                                            </Border>
                                            <Border Background="#1B3A5E" CornerRadius="20" Padding="10,4">
                                                <TextBlock Text="{Binding CargaHoraria}"
                                                           Foreground="#90CAF9"
                                                           FontFamily="Segoe UI" FontSize="11"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Titulo}"
                                                   Foreground="White" FontSize="15" FontWeight="Bold"
                                                   FontFamily="Segoe UI"/>
                                        <TextBlock Text="{Binding Descricao}"
                                                   Foreground="#D8CCF0" FontSize="12"
                                                   FontFamily="Segoe UI" TextWrapping="Wrap"
                                                   Opacity="0.8" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="{Binding TextoBotao}"
                                            Background="{Binding CorBotao}"
                                            IsEnabled="{Binding BotaoAtivo}"
                                            Style="{StaticResource BtnStyle}"
                                            VerticalAlignment="Center" Margin="16,0,0,0"
                                            Click="BtnCandidatar_Click"
                                            Tag="{Binding CursoId}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>