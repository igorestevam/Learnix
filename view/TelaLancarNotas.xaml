<UserControl x:Class="Learnix.TelaLancarNotas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Learnix"
             Background="#1E1E1E">

    <UserControl.Resources>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#2A2040"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#3A2860"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="#3A2860" CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      VerticalAlignment="Center"
                                                      Margin="12,0,0,0"/>
                                    <TextBlock Grid.Column="1" Text="▾" Foreground="#9E8FC0"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <ToggleButton Grid.ColumnSpan="2"
                                                  Background="Transparent" BorderThickness="0"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                  RelativeSource={RelativeSource TemplatedParent}}"/>
                                </Grid>
                            </Border>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#3A2860" CornerRadius="8"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="200">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Padding" Value="12,8"/>
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#4E3A7A"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#4E3A7A"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#3A2860"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#4E3A7A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#3A2860"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSalvarStyle" TargetType="Button" BasedOn="{StaticResource BtnStyle}">
            <Setter Property="Background" Value="#2E7D32"/>
        </Style>

        <Style x:Key="LinhaCard" TargetType="Border">
            <Setter Property="Background" Value="#2A2040"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:SidebarInstrutor x:Name="Sidebar" Grid.Column="0"/>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,32,36,32">

                <TextBlock Text="&#x1F4CB;  Lançar Notas"
                           Foreground="White" FontSize="24" FontWeight="Bold"
                           FontFamily="Segoe UI"/>
                <TextBlock Text="Selecione o curso e lance as notas dos alunos"
                           Foreground="#9E8FC0" FontSize="12"
                           FontFamily="Segoe UI" Margin="0,6,0,24"/>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Selecionar Curso"
                                   Foreground="White" FontSize="15" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                                <ComboBox x:Name="ComboCursos"
                                  Style="{StaticResource ComboStyle}"
                                  SelectionChanged="ComboCursos_SelectionChanged">
                                  <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                               <TextBlock Text="{Binding Titulo}" Foreground="White"
                                               FontFamily="Segoe UI" FontSize="13"/>
                                           </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Grid.Column="1" Content="Carregar Alunos"
                                    Style="{StaticResource BtnStyle}"
                                    Margin="12,0,0,0"
                                    Click="BtnCarregar_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="PainelNotas" Visibility="Collapsed"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Alunos Matriculados"
                                   Foreground="White" FontSize="15" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Margin="0,0,0,12"/>

                        <Grid Margin="16,0,16,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ALUNO"
                                       Foreground="#9E8FC0" FontSize="11"
                                       FontWeight="SemiBold" FontFamily="Segoe UI"/>
                            <TextBlock Grid.Column="1" Text="AV1"
                                       Foreground="#9E8FC0" FontSize="11"
                                       FontWeight="SemiBold" FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="AV2"
                                       Foreground="#9E8FC0" FontSize="11"
                                       FontWeight="SemiBold" FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="AV3"
                                       Foreground="#9E8FC0" FontSize="11"
                                       FontWeight="SemiBold" FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="AÇÃO"
                                       Foreground="#9E8FC0" FontSize="11"
                                       FontWeight="SemiBold" FontFamily="Segoe UI"
                                       HorizontalAlignment="Center" MinWidth="80"/>
                        </Grid>

                        <Separator Background="#9E8FC0" Opacity="0.2" Margin="0,0,0,8"/>

                        <ItemsControl x:Name="ListaAlunos">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource LinhaCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding NomeAluno}"
                                                           Foreground="White" FontSize="13"
                                                           FontFamily="Segoe UI"/>
                                                <TextBlock Text="{Binding Matricula}"
                                                           Foreground="#9E8FC0" FontSize="11"
                                                           FontFamily="Segoe UI"/>
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Text="{Binding NotaAV1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource InputStyle}"
                                                     Margin="6,0" HorizontalAlignment="Center"
                                                     Width="55" TextAlignment="Center"/>
                                            <TextBox Grid.Column="2" Text="{Binding NotaAV2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource InputStyle}"
                                                     Margin="6,0" HorizontalAlignment="Center"
                                                     Width="55" TextAlignment="Center"/>
                                            <TextBox Grid.Column="3" Text="{Binding NotaAV3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource InputStyle}"
                                                     Margin="6,0" HorizontalAlignment="Center"
                                                     Width="55" TextAlignment="Center"/>
                                            <Button Grid.Column="4" Content="Salvar"
                                                    Style="{StaticResource BtnSalvarStyle}"
                                                    Click="BtnSalvarNota_Click"
                                                    Tag="{Binding MatriculaId}"
                                                    MinWidth="80"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border x:Name="PainelSemAlunos" Visibility="Collapsed"
                                Background="#1E1E1E" CornerRadius="8" Padding="20">
                            <TextBlock Text="Nenhum aluno matriculado neste curso."
                                       Foreground="#9E8FC0" FontSize="13" FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"/>
                        </Border>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>