<UserControl x:Class="Learnix.TelaPlayer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Learnix"
             Background="#1E1E1E">

    <UserControl.Resources>
        <Style x:Key="BtnPlayerStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#3A2860"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnNavStyle" TargetType="Button">
            <Setter Property="Background" Value="#4E3A7A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#3A2860"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="borda" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <local:SidebarControl x:Name="Sidebar" Grid.Column="0"/>

        <!-- Área central -->
        <Grid Grid.Column="1" Margin="24,24,12,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Voltar + título -->
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock x:Name="BtnVoltar"
                           Text="&#x2190; Voltar para Aulas"
                           Foreground="#D8CCF0" FontSize="13"
                           FontFamily="Segoe UI" Cursor="Hand"
                           TextDecorations="Underline" Margin="0,0,0,10"
                           MouseLeftButtonDown="BtnVoltar_Click"/>
                <TextBlock x:Name="TxtTituloAula" Text=""
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           FontFamily="Segoe UI"/>
                <TextBlock x:Name="TxtNomeCurso" Text=""
                           Foreground="#9E8FC0" FontSize="13"
                           FontFamily="Segoe UI" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Vídeo -->
            <Border Grid.Row="1" Background="Black" CornerRadius="12,12,0,0"
                    ClipToBounds="True" Height="360">
                <Grid>
                    <MediaElement x:Name="VideoPlayer"
                                  LoadedBehavior="Manual"
                                  UnloadedBehavior="Stop"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  MediaOpened="VideoPlayer_MediaOpened"
                                  MediaEnded="VideoPlayer_MediaEnded"
                                  MediaFailed="VideoPlayer_MediaFailed"/>
                    <StackPanel x:Name="OverlaySemVideo"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Text="&#x25B6;" FontSize="56"
                                   HorizontalAlignment="Center"
                                   Foreground="#4E3A7A" Opacity="0.6"/>
                        <TextBlock Text="Clique em Abrir V&#xED;deo para carregar a aula"
                                   Foreground="#9E8FC0" FontSize="13"
                                   FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Controles -->
            <Border Grid.Row="2" Background="#2A2040" CornerRadius="0,0,12,12"
                    Padding="16,10" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Slider x:Name="SliderVideo" Grid.Row="0"
                            Minimum="0" Maximum="100" Value="0"
                            Margin="0,0,0,8"
                            Foreground="#7E6BAC" Background="#3A2860"
                            ValueChanged="SliderVideo_ValueChanged"
                            IsMoveToPointEnabled="True">
                        <Slider.Resources>
                            <Style TargetType="Thumb">
                                <EventSetter Event="DragStarted"   Handler="SliderVideo_DragStarted"/>
                                <EventSetter Event="DragCompleted" Handler="SliderVideo_DragCompleted"/>
                            </Style>
                        </Slider.Resources>
                    </Slider>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button x:Name="BtnPlayPause" Content="&#x25B6;"
                                    Style="{StaticResource BtnPlayerStyle}"
                                    Click="BtnPlayPause_Click" ToolTip="Play/Pause"/>
                            <Button Content="&#x23F9;" Style="{StaticResource BtnPlayerStyle}"
                                    Click="BtnStop_Click" ToolTip="Parar"/>
                            <Button Content="&#x23EE;" Style="{StaticResource BtnPlayerStyle}"
                                    Click="BtnVoltar10_Click" ToolTip="-10s"/>
                            <Button Content="&#x23ED;" Style="{StaticResource BtnPlayerStyle}"
                                    Click="BtnAvancar10_Click" ToolTip="+10s"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1" x:Name="TxtTempo"
                                   Text="00:00 / 00:00"
                                   Foreground="#9E8FC0" FontSize="12"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <TextBlock Text="&#x1F50A;" FontSize="16"
                                       VerticalAlignment="Center" Margin="0,0,6,0"
                                       Foreground="#D8CCF0"/>
                            <Slider x:Name="SliderVolume" Width="80"
                                    Minimum="0" Maximum="1" Value="0.8"
                                    VerticalAlignment="Center" Margin="0,0,12,0"
                                    Foreground="#7E6BAC"
                                    ValueChanged="SliderVolume_ValueChanged"/>
                            <Button Content="&#x1F4C2; Abrir V&#xED;deo"
                                    Style="{StaticResource BtnPlayerStyle}"
                                    FontSize="13" Padding="12,6"
                                    Click="BtnAbrirVideo_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Navegação de aulas -->
            <Border Grid.Row="3" Background="#1A1430" CornerRadius="10"
                    Padding="16,10" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnAnteriorPlayer" Grid.Column="0"
                            Content="&#x2190; Aula Anterior"
                            Style="{StaticResource BtnNavStyle}"
                            Click="BtnAnteriorPlayer_Click"/>
                    <TextBlock x:Name="TxtContadorPlayer" Grid.Column="1"
                               Foreground="#9E8FC0" FontSize="13" FontFamily="Segoe UI"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button x:Name="BtnProximaPlayer" Grid.Column="2"
                            Content="Pr&#xF3;xima Aula &#x2192;"
                            Style="{StaticResource BtnNavStyle}"
                            Click="BtnProximaPlayer_Click"/>
                </Grid>
            </Border>

            <!-- Abas -->
            <Border Grid.Row="4" Background="#2A2040" CornerRadius="12" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#2A2040">
                        <Border x:Name="AbaMateriaisHeader"
                                Padding="20,12" Cursor="Hand"
                                BorderThickness="0,0,0,2" BorderBrush="#7E6BAC"
                                MouseLeftButtonDown="AbaMateriaisClick">
                            <TextBlock Text="&#x1F4CE; Materiais"
                                       Foreground="White" FontSize="13"
                                       FontFamily="Segoe UI" FontWeight="SemiBold"/>
                        </Border>
                        <Border x:Name="AbaTranscricaoHeader"
                                Padding="20,12" Cursor="Hand"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                MouseLeftButtonDown="AbaTranscricaoClick">
                            <TextBlock Text="&#x1F4DD; Transcri&#xE7;&#xE3;o"
                                       Foreground="#9E8FC0" FontSize="13"
                                       FontFamily="Segoe UI"/>
                        </Border>
                        <Border x:Name="AbaAnotacoesHeader"
                                Padding="20,12" Cursor="Hand"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                MouseLeftButtonDown="AbaAnotacoesClick">
                            <TextBlock Text="&#x270F;&#xFE0F; Anota&#xE7;&#xF5;es"
                                       Foreground="#9E8FC0" FontSize="13"
                                       FontFamily="Segoe UI"/>
                        </Border>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" Padding="20,16"
                                  VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <StackPanel x:Name="AbaMateriais">
                                <TextBlock Text="Material de Apoio"
                                           Foreground="White" FontSize="14" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Margin="0,0,0,12"/>
                                <TextBlock Text="Nenhum material dispon&#xED;vel para esta aula."
                                           Foreground="#9E8FC0" FontSize="13"
                                           FontFamily="Segoe UI"/>
                            </StackPanel>

                            <StackPanel x:Name="AbaTranscricao" Visibility="Collapsed">
                                <TextBlock Text="Transcri&#xE7;&#xE3;o da Aula"
                                           Foreground="White" FontSize="14" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Margin="0,0,0,12"/>
                                <TextBlock Text="Transcri&#xE7;&#xE3;o n&#xE3;o dispon&#xED;vel."
                                           Foreground="#9E8FC0" FontSize="13"
                                           FontFamily="Segoe UI"/>
                            </StackPanel>

                            <StackPanel x:Name="AbaAnotacoes" Visibility="Collapsed">
                                <TextBlock Text="Minhas Anota&#xE7;&#xF5;es"
                                           Foreground="White" FontSize="14" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Margin="0,0,0,12"/>
                                <TextBox x:Name="TxtAnotacoes"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         MinHeight="120" Background="#3A2860"
                                         Foreground="White" BorderThickness="0"
                                         FontFamily="Segoe UI" FontSize="13"
                                         Padding="12" CaretBrush="White"
                                         Text="Digite suas anota&#xE7;&#xF5;es aqui...">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                            <ScrollViewer x:Name="PART_ContentHost"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <Button Content="&#x1F4BE; Salvar Anota&#xE7;&#xF5;es"
                                        Margin="0,10,0,0" HorizontalAlignment="Right"
                                        Background="#4E3A7A" Foreground="White"
                                        BorderThickness="0" Padding="16,8"
                                        FontFamily="Segoe UI" FontSize="13" Cursor="Hand"
                                        Click="BtnSalvarAnotacoes_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="b" Background="{TemplateBinding Background}"
                                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="b" Property="Background" Value="#3A2860"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Lista de aulas lateral direita -->
        <Border Grid.Column="2" Background="#2A2040"
                Margin="12,24,24,24" CornerRadius="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="16,16,16,8">
                    <TextBlock Text="Aulas do Curso" Foreground="White"
                               FontSize="14" FontWeight="Bold" FontFamily="Segoe UI"/>
                    <Separator Background="#9E8FC0" Opacity="0.25" Margin="0,8,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Padding="8,0,8,8">
                    <StackPanel x:Name="ListaAulasPanel"/>
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>
</UserControl>