<Window x:Class="Learnix.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Learnix" Height="160" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E">
    <StackPanel Margin="24">
        <TextBlock x:Name="TxtLabel" Text="Informe o valor:"
                   Foreground="White" FontSize="13" FontFamily="Segoe UI"
                   Margin="0,0,0,10"/>
        <Border Background="#3A2860" CornerRadius="8" Padding="12,8" Margin="0,0,0,16">
            <TextBox x:Name="TxtInput" Background="Transparent"
                     Foreground="White" BorderThickness="0"
                     FontSize="13" FontFamily="Segoe UI"
                     CaretBrush="White"
                     KeyDown="TxtInput_KeyDown"/>
        </Border>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Click="BtnCancelar_Click"
                    Background="#3A2060" Foreground="White"
                    BorderThickness="0" Padding="16,8" Margin="0,0,8,0"
                    Cursor="Hand" FontFamily="Segoe UI"/>
            <Button Content="OK" Click="BtnOk_Click"
                    Background="#4E3A7A" Foreground="White"
                    BorderThickness="0" Padding="16,8"
                    Cursor="Hand" FontFamily="Segoe UI"/>
        </StackPanel>
    </StackPanel>
</Window>