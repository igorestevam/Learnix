<UserControl x:Class="Learnix.TelaMeusCursosInstrutor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Learnix"
             Background="#1E1E1E">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#2A2040"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#4E3A7A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#3A2860"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnSairStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#5C1010"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="borda" Property="Background" Value="#2A2040"/>
                                <Setter TargetName="borda" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#3A2860"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnSalvarStyle" TargetType="Button" BasedOn="{StaticResource BtnStyle}">
            <Setter Property="Background" Value="#2E7D32"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:SidebarInstrutor x:Name="Sidebar" Grid.Column="0"/>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,32,36,32">

                <TextBlock Text="&#x1F4DA;  Meus Cursos"
                           Foreground="White" FontSize="24" FontWeight="Bold"
                           FontFamily="Segoe UI"/>
                <TextBlock Text="Cursos que voc&#xEA; est&#xE1; ministrando"
                           Foreground="#9E8FC0" FontSize="12"
                           FontFamily="Segoe UI" Margin="0,6,0,24"/>

                <Border x:Name="PainelVazio" Visibility="Collapsed"
                        Style="{StaticResource CardStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#x1F4DA;" FontSize="48"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="Voc&#xEA; ainda n&#xE3;o est&#xE1; vinculado a nenhum curso."
                                   Foreground="#9E8FC0" FontSize="14" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Use Escolher Curso para se candidatar."
                                   Foreground="#9E8FC0" FontSize="12" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Lista de cursos com painel de notas embutido -->
                <ItemsControl x:Name="ListaCursos">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,12">

                                <!-- Card do curso -->
                                <Border Style="{StaticResource CardStyle}" Margin="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <Border Background="{Binding CorCategoria}" CornerRadius="20"
                                                        Padding="10,4" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding NomeCategoria}"
                                                               Foreground="{Binding CorTextoCategoria}"
                                                               FontFamily="Segoe UI" FontSize="11"/>
                                                </Border>
                                                <Border Background="#1B3A5E" CornerRadius="20" Padding="10,4">
                                                    <TextBlock Text="{Binding CargaHoraria}"
                                                               Foreground="#90CAF9"
                                                               FontFamily="Segoe UI" FontSize="11"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Titulo}"
                                                       Foreground="White" FontSize="15" FontWeight="Bold"
                                                       FontFamily="Segoe UI"/>
                                            <TextBlock Text="{Binding Descricao}"
                                                       Foreground="#D8CCF0" FontSize="12"
                                                       FontFamily="Segoe UI" TextWrapping="Wrap"
                                                       Opacity="0.8" Margin="0,4,0,8"/>
                                            <TextBlock Text="{Binding NumAlunos}"
                                                       Foreground="#9E8FC0" FontSize="12"
                                                       FontFamily="Segoe UI"/>
                                        </StackPanel>

                                        <!-- Botões -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="16,0,0,0">
                                            <Button Content="&#x1F4CB; Lan&#xE7;ar Notas"
                                                    Style="{StaticResource BtnStyle}"
                                                    Margin="0,0,8,0"
                                                    Click="BtnLancarNotas_Click"
                                                    Tag="{Binding CursoId}"/>
                                            <Button Content="&#x1F6AA; Sair"
                                                    Style="{StaticResource BtnSairStyle}"
                                                    Background="#7B1A1A"
                                                    IsEnabled="{Binding PodeSair}"
                                                    Click="BtnSairCurso_Click"
                                                    Tag="{Binding CursoId}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Painel de notas inline (oculto por padrão) -->
                                <Border x:Name="PainelNotasInline"
                                        Visibility="{Binding PainelNotasVisivel}"
                                        Background="#221A38" CornerRadius="0,0,12,12"
                                        Padding="20,16" Margin="0,-4,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Alunos Matriculados"
                                                   Foreground="White" FontSize="14" FontWeight="SemiBold"
                                                   FontFamily="Segoe UI" Margin="0,0,0,12"/>

                                        <!-- Cabeçalho da tabela -->
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="ALUNO" Foreground="#9E8FC0"
                                                       FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                            <TextBlock Grid.Column="1" Text="AV1" Foreground="#9E8FC0"
                                                       FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="AV2" Foreground="#9E8FC0"
                                                       FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="AV3" Foreground="#9E8FC0"
                                                       FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="A&#xC7;&#xC3;O" Foreground="#9E8FC0"
                                                       FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"
                                                       HorizontalAlignment="Center" MinWidth="80"/>
                                        </Grid>

                                        <Separator Background="#9E8FC0" Opacity="0.2" Margin="0,0,0,8"/>

                                        <ItemsControl ItemsSource="{Binding Alunos}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#2A2040" CornerRadius="8"
                                                            Padding="12,10" Margin="0,0,0,6">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="2*"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding NomeAluno}"
                                                                           Foreground="White" FontSize="13"
                                                                           FontFamily="Segoe UI"/>
                                                                <TextBlock Text="{Binding Matricula}"
                                                                           Foreground="#9E8FC0" FontSize="11"
                                                                           FontFamily="Segoe UI"/>
                                                            </StackPanel>
                                                            <TextBox Grid.Column="1"
                                                                     Text="{Binding NotaAV1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     Style="{StaticResource InputStyle}"
                                                                     Margin="6,0" Width="55" TextAlignment="Center"/>
                                                            <TextBox Grid.Column="2"
                                                                     Text="{Binding NotaAV2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     Style="{StaticResource InputStyle}"
                                                                     Margin="6,0" Width="55" TextAlignment="Center"/>
                                                            <TextBox Grid.Column="3"
                                                                     Text="{Binding NotaAV3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     Style="{StaticResource InputStyle}"
                                                                     Margin="6,0" Width="55" TextAlignment="Center"/>
                                                            <Button Grid.Column="4" Content="Salvar"
                                                                    Style="{StaticResource BtnSalvarStyle}"
                                                                    Click="BtnSalvarNota_Click"
                                                                    Tag="{Binding MatriculaId}"
                                                                    MinWidth="80"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Border x:Name="PainelSemAlunos"
                                                Visibility="{Binding PainelSemAlunosVisivel}"
                                                Background="#1E1E1E" CornerRadius="8" Padding="20">
                                            <TextBlock Text="Nenhum aluno matriculado neste curso."
                                                       Foreground="#9E8FC0" FontSize="13"
                                                       FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                                        </Border>

                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
