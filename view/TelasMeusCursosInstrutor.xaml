<UserControl x:Class="Learnix.TelaMeusCursosInstrutor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Learnix"
             Background="#1E1E1E">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#2A2040"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#4E3A7A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#3A2860"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnSairStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#5C1010"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="borda" Property="Background" Value="#2A2040"/>
                                <Setter TargetName="borda" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:SidebarInstrutor x:Name="Sidebar" Grid.Column="0"/>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,32,36,32">

                <TextBlock Text="&#x1F4DA;  Meus Cursos"
                           Foreground="White" FontSize="24" FontWeight="Bold"
                           FontFamily="Segoe UI"/>
                <TextBlock Text="Cursos que voc&#xEA; est&#xE1; ministrando"
                           Foreground="#9E8FC0" FontSize="12"
                           FontFamily="Segoe UI" Margin="0,6,0,24"/>

                <Border x:Name="PainelVazio" Visibility="Collapsed"
                        Style="{StaticResource CardStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#x1F4DA;" FontSize="48"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="Voc&#xEA; ainda n&#xE3;o est&#xE1; vinculado a nenhum curso."
                                   Foreground="#9E8FC0" FontSize="14" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Use Escolher Curso para se candidatar."
                                   Foreground="#9E8FC0" FontSize="12" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <ItemsControl x:Name="ListaCursos">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,12">
                                <Border Style="{StaticResource CardStyle}" Margin="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <Border Background="{Binding CorCategoria}" CornerRadius="20"
                                                        Padding="10,4" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding NomeCategoria}"
                                                               Foreground="{Binding CorTextoCategoria}"
                                                               FontFamily="Segoe UI" FontSize="11"/>
                                                </Border>
                                                <Border Background="#1B3A5E" CornerRadius="20" Padding="10,4">
                                                    <TextBlock Text="{Binding CargaHoraria}"
                                                               Foreground="#90CAF9"
                                                               FontFamily="Segoe UI" FontSize="11"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Titulo}"
                                                       Foreground="White" FontSize="15" FontWeight="Bold"
                                                       FontFamily="Segoe UI"/>
                                            <TextBlock Text="{Binding Descricao}"
                                                       Foreground="#D8CCF0" FontSize="12"
                                                       FontFamily="Segoe UI" TextWrapping="Wrap"
                                                       Opacity="0.8" Margin="0,4,0,8"/>
                                            <TextBlock Text="{Binding NumAlunos}"
                                                       Foreground="#9E8FC0" FontSize="12"
                                                       FontFamily="Segoe UI"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="16,0,0,0">
                                            <Button Content="&#x270F; Editar"
                                                    Style="{StaticResource BtnStyle}"
                                                    Margin="0,0,8,0"
                                                    Click="BtnEditarCurso_Click"
                                                    Tag="{Binding CursoId}"/>
                                            <Button Content="&#x1F4CB; Lan&#xE7;ar Notas"
                                                    Style="{StaticResource BtnStyle}"
                                                    Margin="0,0,8,0"
                                                    Click="BtnLancarNotas_Click"
                                                    Tag="{Binding CursoId}"/>
                                            <Button Content="&#x1F6AA; Sair"
                                                    Style="{StaticResource BtnSairStyle}"
                                                    Background="#7B1A1A"
                                                    IsEnabled="{Binding PodeSair}"
                                                    Click="BtnSairCurso_Click"
                                                    Tag="{Binding CursoId}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <Grid x:Name="PainelAlunosPendentes" Visibility="Collapsed" Background="#B3000000" Grid.Column="1" Panel.ZIndex="100">
            <Border Background="#1E1E1E" CornerRadius="12" Padding="32" Width="500" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="&#x1F4CB; ALUNOS AGUARDANDO CORREÇÃO" Foreground="White" FontSize="18" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,16"/>

                    <TextBlock x:Name="TxtSemAlunos" Text="Nenhum aluno aguardando correção neste curso." Foreground="#9E8FC0" Visibility="Collapsed" FontFamily="Segoe UI" Margin="0,0,0,16"/>

                    <ItemsControl x:Name="ListaAlunosPendentes" MaxHeight="300">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2A2040" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding AlunoNome}" Foreground="White" FontWeight="SemiBold" FontSize="14" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="Ler Respostas" Background="#D84315" Foreground="White" BorderThickness="0" Padding="12,6" Cursor="Hand"
                                                Click="BtnAbrirCorrecaoAluno_Click" Tag="{Binding MatriculaId}">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="Fechar" Click="BtnFecharListaPendentes_Click" Background="#3A2860" Foreground="White" BorderThickness="0" Padding="16,8" Cursor="Hand" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="PainelCorrecao" Visibility="Collapsed" Background="#CC000000" Grid.ColumnSpan="10" Grid.RowSpan="10" Panel.ZIndex="200">
            <Border Background="#1E1E1E" CornerRadius="12" Padding="0" Width="700" HorizontalAlignment="Center" VerticalAlignment="Center" MaxHeight="650">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#2A2040" CornerRadius="12,12,0,0" Padding="32,24">
                        <StackPanel>
                            <TextBlock Text="&#x1F468;&#x200D;&#x1F3EB; CORREÇÃO DE ATIVIDADES" Foreground="White" FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"/>
                            <TextBlock x:Name="TxtNomeAlunoCorrecao" Text="Aluno: " Foreground="#9E8FC0" FontSize="14" FontFamily="Segoe UI" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="32,24,32,16">
                        <ItemsControl x:Name="ListaRespostasParaCorrigir">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2A2040" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                                        <StackPanel>

                                            <TextBlock Text="{Binding NumeroPergunta, StringFormat='PERGUNTA {0}'}" Foreground="#9E8FC0" FontSize="11" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding Pergunta}" Foreground="White" FontSize="14" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,0,0,20"/>

                                            <TextBlock Text="RESPOSTA DO ALUNO" Foreground="#9E8FC0" FontSize="11" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                                            <Border Background="#1E1E1E" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                                                <TextBlock Text="{Binding Resposta}" Foreground="#D8CCF0" FontSize="14" FontFamily="Segoe UI" TextWrapping="Wrap"/>
                                            </Border>

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <TextBlock Text="NOTA (0 a 10):" Foreground="#9E8FC0" FontSize="12" FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <TextBox Text="{Binding NotaDigitada, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                         Background="#3A2860" Foreground="White" BorderThickness="0" Padding="12,10" Width="70" TextAlignment="Center" FontFamily="Segoe UI" FontSize="15" FontWeight="Bold">
                                                    <TextBox.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="8"/>
                                                        </Style>
                                                    </TextBox.Resources>
                                                </TextBox>
                                            </StackPanel>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="#221A38" CornerRadius="0,0,12,12" Padding="32,20">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancelar" Click="BtnFecharCorrecao_Click" Background="Transparent" Foreground="#D8CCF0" BorderThickness="0" Padding="16,10" Margin="0,0,16,0" Cursor="Hand" FontFamily="Segoe UI" FontSize="14"/>
                            <Button Content="&#x2714; Salvar Notas e Avaliar" Click="BtnSalvarNotasProfessor_Click" Background="#2E7D32" Foreground="White" BorderThickness="0" Padding="24,12" Cursor="Hand" FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>