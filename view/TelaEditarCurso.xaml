<UserControl x:Class="Learnix.TelaEditarCurso"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Learnix"
             Background="#1E1E1E">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#2A2040"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24,20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9E8FC0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#3A2860"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#4E3A7A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#3A2860"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnSalvarStyle" TargetType="Button" BasedOn="{StaticResource BtnStyle}">
            <Setter Property="Background" Value="#2E7D32"/>
        </Style>
        <Style x:Key="BtnRemoverStyle" TargetType="Button" BasedOn="{StaticResource BtnStyle}">
            <Setter Property="Background" Value="#7B1A1A"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:SidebarInstrutor x:Name="Sidebar" Grid.Column="0"/>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,32,36,32">

                <TextBlock x:Name="BtnVoltar"
                           Text="&#x2190; Voltar para Meus Cursos"
                           Foreground="#D8CCF0" FontSize="13"
                           FontFamily="Segoe UI" Cursor="Hand"
                           TextDecorations="Underline" Margin="0,0,0,20"
                           MouseLeftButtonDown="BtnVoltar_Click"/>

                <TextBlock Text="&#x270F;  Editar Curso"
                           Foreground="White" FontSize="24" FontWeight="Bold"
                           FontFamily="Segoe UI"/>
                <TextBlock Text="Edite as informa&#xE7;&#xF5;es do curso"
                           Foreground="#9E8FC0" FontSize="12"
                           FontFamily="Segoe UI" Margin="0,6,0,24"/>

                <!-- Dados do curso -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Informa&#xE7;&#xF5;es do Curso"
                                   Foreground="White" FontSize="15" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Margin="0,0,0,16"/>

                        <TextBlock Text="T&#xCD;TULO" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="TxtTitulo" Style="{StaticResource InputStyle}"/>

                        <TextBlock Text="DESCRI&#xC7;&#xC3;O" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="TxtDescricao" Style="{StaticResource InputStyle}"
                                 AcceptsReturn="True" MinHeight="80" TextWrapping="Wrap"/>

                        <TextBlock Text="CARGA HOR&#xC1;RIA (horas)" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="TxtCargaHoraria" Style="{StaticResource InputStyle}"/>

                        <Button Content="&#x2714; Salvar Altera&#xE7;&#xF5;es"
                                Style="{StaticResource BtnSalvarStyle}"
                                HorizontalAlignment="Right"
                                Click="BtnSalvarCurso_Click"/>
                    </StackPanel>
                </Border>

                <!-- Módulos e aulas -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="M&#xF3;dulos e Aulas"
                                       Foreground="White" FontSize="15" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="+ Adicionar M&#xF3;dulo"
                                    Style="{StaticResource BtnStyle}"
                                    Click="BtnAdicionarModulo_Click"/>
                        </Grid>

                        <Border x:Name="PainelSemModulos" Visibility="Collapsed"
                                Background="#1E1E1E" CornerRadius="8" Padding="20">
                            <TextBlock Text="Nenhum m&#xF3;dulo cadastrado."
                                       Foreground="#9E8FC0" FontSize="13"
                                       FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                        </Border>

                        <ItemsControl x:Name="ListaModulos">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1E1E1E" CornerRadius="10"
                                            Padding="16,14" Margin="0,0,0,10">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding TituloModulo}"
                                                           Foreground="White" FontSize="13"
                                                           FontWeight="SemiBold" FontFamily="Segoe UI"
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Content="+ Aula"
                                                        Style="{StaticResource BtnStyle}"
                                                        Padding="10,6" Margin="8,0"
                                                        Click="BtnAdicionarAula_Click"
                                                        Tag="{Binding ModuloId}"/>
                                                <Button Grid.Column="2" Content="&#x1F5D1;"
                                                        Style="{StaticResource BtnRemoverStyle}"
                                                        Padding="10,6"
                                                        Click="BtnRemoverModulo_Click"
                                                        Tag="{Binding ModuloId}"/>
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding Aulas}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#2A2040" CornerRadius="8"
                                                                Padding="12,10" Margin="0,0,0,6">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding NumeroAula}"
                                                                           Foreground="#9E8FC0" FontSize="12"
                                                                           FontFamily="Segoe UI"
                                                                           VerticalAlignment="Top"
                                                                           Margin="0,4,12,0"/>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="{Binding TituloAula}"
                                                                               Foreground="White" FontSize="13"
                                                                               FontFamily="Segoe UI"/>
                                                                    <TextBlock Text="{Binding DuracaoAula}"
                                                                               Foreground="#9E8FC0" FontSize="11"
                                                                               FontFamily="Segoe UI" Margin="0,2,0,6"/>
                                                                    <!-- Vídeo selecionado -->
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding VideoNome}"
                                                                                   Foreground="#9E8FC0" FontSize="11"
                                                                                   FontFamily="Segoe UI"
                                                                                   VerticalAlignment="Center"
                                                                                   Margin="0,0,8,0"/>
                                                                        <Button Content="&#x1F4C2; Selecionar V&#xED;deo"
                                                                                Background="#4E3A7A" Foreground="White"
                                                                                BorderThickness="0" Padding="8,4"
                                                                                FontSize="11" FontFamily="Segoe UI"
                                                                                Cursor="Hand"
                                                                                Click="BtnSalvarUrl_Click"
                                                                                Tag="{Binding AulaId}">
                                                                            <Button.Template>
                                                                                <ControlTemplate TargetType="Button">
                                                                                    <Border x:Name="b"
                                                                                            Background="{TemplateBinding Background}"
                                                                                            CornerRadius="6"
                                                                                            Padding="{TemplateBinding Padding}">
                                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                                          VerticalAlignment="Center"/>
                                                                                    </Border>
                                                                                    <ControlTemplate.Triggers>
                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                            <Setter TargetName="b" Property="Background" Value="#3A2860"/>
                                                                                        </Trigger>
                                                                                    </ControlTemplate.Triggers>
                                                                                </ControlTemplate>
                                                                            </Button.Template>
                                                                        </Button>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                                <Button Grid.Column="2" Content="&#x1F5D1;"
                                                                        Style="{StaticResource BtnRemoverStyle}"
                                                                        Padding="8,6" VerticalAlignment="Top"
                                                                        Click="BtnRemoverAula_Click"
                                                                        Tag="{Binding AulaId}"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>