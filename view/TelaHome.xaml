<UserControl x:Class="Learnix.TelaHome"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Learnix"
             Background="#1E1E1E">

    <UserControl.Resources>
        <Style x:Key="CardResumoStyle" TargetType="Border">
            <Setter Property="Background" Value="#2A2040"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
        </Style>
        <Style x:Key="CardCursoStyle" TargetType="Border">
            <Setter Property="Background" Value="#2A2040"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="BtnAcessarStyle" TargetType="Button">
            <Setter Property="Background" Value="#4E3A7A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#3A2860"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:SidebarControl x:Name="Sidebar" Grid.Column="0"/>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="36,32,36,32">

                <!-- Cabeçalho -->
                <TextBlock Text="Bem-vindo de volta! &#x1F44B;"
                           Foreground="#D8CCF0" FontSize="13" FontFamily="Segoe UI" Opacity="0.8"/>
                <TextBlock x:Name="TxtNomeAluno" Text="Aluno"
                           Foreground="White" FontSize="26" FontWeight="Bold"
                           FontFamily="Segoe UI" Margin="0,4,0,2"/>
                <TextBlock x:Name="TxtData" Text=""
                           Foreground="#9E8FC0" FontSize="12"
                           FontFamily="Segoe UI" Margin="0,0,0,26"/>

                <!-- Cards de resumo — x:Name para popular do banco -->
                <UniformGrid Columns="3" Margin="0,0,0,28">
                    <Border Style="{StaticResource CardResumoStyle}" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="&#x1F4DA;  Cursos Ativos"
                                       Foreground="#D8CCF0" FontSize="12" FontFamily="Segoe UI" Opacity="0.75"/>
                            <TextBlock x:Name="TxtCursosAtivos" Text="0"
                                       Foreground="White" FontSize="28" FontWeight="Bold"
                                       FontFamily="Segoe UI" Margin="0,6,0,2"/>
                            <TextBlock Text="em andamento" Foreground="#9E8FC0"
                                       FontSize="11" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardResumoStyle}" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="&#x1F4CB;  M&#xE9;dia Geral"
                                       Foreground="#D8CCF0" FontSize="12" FontFamily="Segoe UI" Opacity="0.75"/>
                            <TextBlock x:Name="TxtMediaGeral" Text="—"
                                       Foreground="White" FontSize="28" FontWeight="Bold"
                                       FontFamily="Segoe UI" Margin="0,6,0,2"/>
                            <TextBlock Text="pontos" Foreground="#9E8FC0"
                                       FontSize="11" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardResumoStyle}">
                        <StackPanel>
                            <TextBlock Text="&#x23F0;  Pendentes"
                                       Foreground="#D8CCF0" FontSize="12" FontFamily="Segoe UI" Opacity="0.75"/>
                            <TextBlock x:Name="TxtPendentes" Text="0"
                                       Foreground="White" FontSize="28" FontWeight="Bold"
                                       FontFamily="Segoe UI" Margin="0,6,0,2"/>
                            <TextBlock Text="atividades" Foreground="#9E8FC0"
                                       FontSize="11" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Continuar estudando -->
                <TextBlock Text="Continuar estudando"
                           Foreground="White" FontSize="16" FontWeight="SemiBold"
                           FontFamily="Segoe UI"/>
                <Separator Background="#9E8FC0" Opacity="0.25" Margin="0,8,0,14"/>

                <Border x:Name="PainelSemCursos" Visibility="Collapsed"
                        Style="{StaticResource CardCursoStyle}">
                    <TextBlock Text="Você ainda não está matriculado em nenhum curso."
                               Foreground="#9E8FC0" FontSize="13" FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                </Border>

                <ItemsControl x:Name="ListaCursosHome">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardCursoStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding TituloCurso}"
                                                   Foreground="White" FontSize="14" FontWeight="SemiBold"
                                                   FontFamily="Segoe UI"/>
                                        <TextBlock Text="{Binding SubtituloInstrutor}"
                                                   Foreground="#9E8FC0" FontSize="12"
                                                   FontFamily="Segoe UI" Margin="0,4,0,10"/>
                                        <Grid Height="6">
                                            <Border Background="#3A2860" CornerRadius="3"/>
                                            <Border Background="#7E6BAC" CornerRadius="3"
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding LarguraBarra}"/>
                                        </Grid>
                                        <TextBlock Text="{Binding PercentualTexto}"
                                                   Foreground="#9E8FC0" FontSize="11"
                                                   FontFamily="Segoe UI" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Continuar &#x2192;"
                                            Style="{StaticResource BtnAcessarStyle}"
                                            VerticalAlignment="Center"
                                            Click="BtnContinuar_Click"
                                            Tag="{Binding MatriculaId}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Próximas Atividades -->
                <TextBlock Text="Pr&#xF3;ximas Atividades"
                           Foreground="White" FontSize="16" FontWeight="SemiBold"
                           FontFamily="Segoe UI" Margin="0,14,0,0"/>
                <Separator Background="#9E8FC0" Opacity="0.25" Margin="0,8,0,14"/>

                <Border x:Name="PainelSemAtividades" Visibility="Collapsed"
                        Style="{StaticResource CardCursoStyle}">
                    <TextBlock Text="Nenhuma atividade pendente."
                               Foreground="#9E8FC0" FontSize="13" FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                </Border>

                <ItemsControl x:Name="ListaAtividades">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardCursoStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#4E3A7A" CornerRadius="10"
                                            Width="46" Height="46" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding Dia}" Foreground="White" FontSize="15"
                                                   FontWeight="Bold" FontFamily="Segoe UI"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Titulo}"
                                                   Foreground="White" FontSize="14" FontWeight="SemiBold"
                                                   FontFamily="Segoe UI"/>
                                        <TextBlock Text="{Binding Subtitulo}"
                                                   Foreground="#9E8FC0" FontSize="12"
                                                   FontFamily="Segoe UI" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>