<UserControl x:Class="Learnix.TelaPerfil"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Learnix"
             Background="#1E1E1E">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#2A2040"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="24,20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9E8FC0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="InputEditStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#3A2860"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnEditarStyle" TargetType="Button">
            <Setter Property="Background" Value="#4E3A7A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#3A2860"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#2C1F4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnSalvarStyle" TargetType="Button" BasedOn="{StaticResource BtnEditarStyle}">
            <Setter Property="Background" Value="#2E7D32"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:SidebarControl x:Name="Sidebar" Grid.Column="0"/>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,32,36,32">

                <TextBlock Text="&#x1F464;  Meu Perfil"
                           Foreground="White" FontSize="24" FontWeight="Bold"
                           FontFamily="Segoe UI"/>
                <TextBlock Text="Gerencie suas informações pessoais"
                           Foreground="#9E8FC0" FontSize="12"
                           FontFamily="Segoe UI" Margin="0,6,0,28"/>

                <!-- Avatar + nome -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="80" Height="80"
                                CornerRadius="40" Background="#4E3A7A"
                                Margin="0,0,20,0">
                            <TextBlock x:Name="TxtIniciais" Text="AL"
                                       Foreground="White" FontSize="26" FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtNomePerfil" Text="Aluno"
                                       Foreground="White" FontSize="20"
                                       FontWeight="Bold" FontFamily="Segoe UI"/>
                            <TextBlock x:Name="TxtEmailPerfil" Text=""
                                       Foreground="#9E8FC0" FontSize="13"
                                       FontFamily="Segoe UI" Margin="0,4,0,0"/>
                            <Border Background="#3A2860" CornerRadius="20"
                                    Padding="12,4" HorizontalAlignment="Left" Margin="0,8,0,0">
                                <TextBlock Text="&#x1F393; Aluno" Foreground="#D8CCF0"
                                           FontFamily="Segoe UI" FontSize="12"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                            <Button x:Name="BtnEditar" Content="&#x270F;&#xFE0F; Editar"
                                    Style="{StaticResource BtnEditarStyle}"
                                    Margin="0,0,8,0" Click="BtnEditar_Click"/>
                            <Button x:Name="BtnSalvar" Content="&#x2714; Salvar"
                                    Style="{StaticResource BtnSalvarStyle}"
                                    Visibility="Collapsed" Click="BtnSalvar_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Dados pessoais -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Dados Pessoais"
                                   Foreground="White" FontSize="15" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Margin="0,0,0,16"/>
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="NOME COMPLETO" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="TxtEditNome" Style="{StaticResource InputEditStyle}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="E-MAIL" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="TxtEditEmail" Style="{StaticResource InputEditStyle}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="MATRÍCULA" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="TxtMatricula" Style="{StaticResource InputEditStyle}"
                                         IsReadOnly="True" Opacity="0.7"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="MEMBRO DESDE" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="TxtMembroDesde" Style="{StaticResource InputEditStyle}"
                                         IsReadOnly="True" Opacity="0.7"/>
                            </StackPanel>

                            <!-- Estilo de Aprendizagem — novo campo populado pelo code-behind -->
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="ESTILO DE APRENDIZAGEM" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="TxtEstilo" Text="—"
                                         Style="{StaticResource InputEditStyle}"
                                         IsReadOnly="True"
                                         Opacity="0.7"/>
                            </StackPanel>

                            <!-- Ritmo Sugerido — novo campo populado pelo code-behind -->
                            <StackPanel>
                                <TextBlock Text="RITMO SUGERIDO" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="TxtRitmo" Text="—"
                                         Style="{StaticResource InputEditStyle}"
                                         IsReadOnly="True"
                                         Opacity="0.7"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Resumo acadêmico dinâmico -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Resumo Acadêmico"
                                   Foreground="White" FontSize="15" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Margin="0,0,0,16"/>
                        <UniformGrid Columns="4">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="TxtTotalCursos" Text="0"
                                           Foreground="White" FontSize="28" FontWeight="Bold"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                                <TextBlock Text="Cursos" Foreground="#9E8FC0"
                                           FontSize="12" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="TxtMediaGeral" Text="—"
                                           Foreground="#A5D6A7" FontSize="28" FontWeight="Bold"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                                <TextBlock Text="Média" Foreground="#9E8FC0"
                                           FontSize="12" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="TxtHorasEstudadas" Text="0h"
                                           Foreground="#90CAF9" FontSize="28" FontWeight="Bold"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                                <TextBlock Text="Estudadas" Foreground="#9E8FC0"
                                           FontSize="12" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="TxtAprovados" Text="0"
                                           Foreground="#FFCC80" FontSize="28" FontWeight="Bold"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                                <TextBlock Text="Aprovados" Foreground="#9E8FC0"
                                           FontSize="12" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>