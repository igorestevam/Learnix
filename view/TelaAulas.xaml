<UserControl x:Class="Learnix.TelaAulas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Learnix"
             Background="#1E1E1E">

    <UserControl.Resources>

        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#4E3A7A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#3A2860"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="borda" Property="Background" Value="#2E7D32"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:SidebarControl x:Name="Sidebar" Grid.Column="0"/>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Cabeçalho do curso -->
            <Border Grid.Row="0" Background="#2A2040" Padding="32,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="BtnVoltar"
                                   Text="&#x2190; Voltar para Meus Cursos"
                                   Foreground="#D8CCF0" FontSize="12"
                                   FontFamily="Segoe UI" Cursor="Hand"
                                   TextDecorations="Underline"
                                   Margin="0,0,0,16"
                                   MouseLeftButtonDown="BtnVoltar_Click"/>
                        <TextBlock x:Name="TxtNomeCurso" Text=""
                                   Foreground="White" FontSize="20" FontWeight="Bold"
                                   FontFamily="Segoe UI"/>
                        <TextBlock x:Name="TxtProfessor" Text=""
                                   Foreground="#9E8FC0" FontSize="13"
                                   FontFamily="Segoe UI" Margin="0,6,0,4"/>
                        <TextBlock x:Name="TxtAulaAtual" Text=""
                                   Foreground="#D8CCF0" FontSize="13"
                                   FontFamily="Segoe UI" Margin="0,4,0,0"/>
                    </StackPanel>
                    <!-- Progresso -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                HorizontalAlignment="Center" Margin="24,0,0,0">
                        <Border Width="90" Height="90" CornerRadius="45" Background="#3A2860">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock x:Name="TxtProgresso" Text="0%"
                                           Foreground="White" FontSize="22"
                                           FontWeight="Bold" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="concluído"
                                           Foreground="#9E8FC0" FontSize="10"
                                           FontFamily="Segoe UI"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Lista de aulas -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="PainelAulas" Margin="32,24,32,16"/>
            </ScrollViewer>

            <!-- Botões de navegação -->
            <Border Grid.Row="2" Background="#2A2040" Padding="32,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnAnterior" Grid.Column="0"
                            Content="&#x2190; Aula Anterior"
                            Style="{StaticResource BtnStyle}"
                            Click="BtnAnterior_Click"/>
                    <TextBlock x:Name="TxtContadorAulas" Grid.Column="1"
                               Foreground="#9E8FC0" FontSize="13" FontFamily="Segoe UI"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button x:Name="BtnProxima" Grid.Column="2"
                            Content="Próxima Aula &#x2192;"
                            Style="{StaticResource BtnStyle}"
                            Click="BtnProxima_Click"/>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>