<UserControl x:Class="Learnix.TelaNotas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Learnix"
             Background="#1E1E1E">

    <UserControl.Resources>

        <Style x:Key="HeaderCelula" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9E8FC0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="CelulaTxt" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D8CCF0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="LinhaCard" TargetType="Border">
            <Setter Property="Background" Value="#2A2040"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:SidebarControl x:Name="Sidebar" Grid.Column="0"/>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,32,36,32">

                <!-- Título -->
                <TextBlock Text="&#x1F4CB;  Minhas Notas"
                           Foreground="White" FontSize="24" FontWeight="Bold"
                           FontFamily="Segoe UI"/>
                <TextBlock Text="Acompanhe seu desempenho em cada disciplina"
                           Foreground="#9E8FC0" FontSize="12"
                           FontFamily="Segoe UI" Margin="0,6,0,24"/>

                <!-- Cards resumo -->
                <UniformGrid Columns="3" Margin="0,0,0,28">
                    <Border Background="#2A2040" CornerRadius="12" Padding="20,16" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="M&#xE9;dia Geral" Foreground="#D8CCF0"
                                       FontSize="12" FontFamily="Segoe UI" Opacity="0.75"/>
                            <TextBlock Text="8,4" Foreground="White" FontSize="28"
                                       FontWeight="Bold" FontFamily="Segoe UI" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#2A2040" CornerRadius="12" Padding="20,16" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Disciplinas" Foreground="#D8CCF0"
                                       FontSize="12" FontFamily="Segoe UI" Opacity="0.75"/>
                            <TextBlock Text="4" Foreground="White" FontSize="28"
                                       FontWeight="Bold" FontFamily="Segoe UI" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#2A2040" CornerRadius="12" Padding="20,16">
                        <StackPanel>
                            <TextBlock Text="Situa&#xE7;&#xE3;o" Foreground="#D8CCF0"
                                       FontSize="12" FontFamily="Segoe UI" Opacity="0.75"/>
                            <TextBlock Text="Aprovado" Foreground="#A5D6A7"
                                       FontSize="20" FontWeight="Bold"
                                       FontFamily="Segoe UI" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <TextBlock Text="Detalhamento por Disciplina"
                           Foreground="White" FontSize="15" FontWeight="SemiBold"
                           FontFamily="Segoe UI"/>
                <Separator Background="#9E8FC0" Opacity="0.25" Margin="0,8,0,12"/>

                <!-- Cabeçalho da tabela -->
                <Grid Margin="18,0,18,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="DISCIPLINA"    Style="{StaticResource HeaderCelula}"/>
                    <TextBlock Grid.Column="1" Text="AV1"           Style="{StaticResource HeaderCelula}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="AV2"           Style="{StaticResource HeaderCelula}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="AV3"           Style="{StaticResource HeaderCelula}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="M&#xC9;DIA"    Style="{StaticResource HeaderCelula}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="STATUS"        Style="{StaticResource HeaderCelula}" HorizontalAlignment="Center"/>
                </Grid>

                <!-- Linha 1 - Aprovado -->
                <Border Style="{StaticResource LinhaCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Algoritmos e Est. de Dados"
                                       Foreground="White" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"/>
                            <TextBlock Text="Prof. Carlos Lima"
                                       Foreground="#9E8FC0" FontSize="11"
                                       FontFamily="Segoe UI" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="8,5" Style="{StaticResource CelulaTxt}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="9,0" Style="{StaticResource CelulaTxt}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="8,0" Style="{StaticResource CelulaTxt}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="8,5" Foreground="#A5D6A7"
                                   FontSize="14" FontWeight="Bold" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Border Grid.Column="5" Background="#1B5E20" CornerRadius="20"
                                Padding="10,4" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Aprovado" Foreground="#A5D6A7"
                                       FontSize="11" FontFamily="Segoe UI"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Linha 2 - Aprovado -->
                <Border Style="{StaticResource LinhaCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="C&#xE1;lculo I"
                                       Foreground="White" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"/>
                            <TextBlock Text="Prof. Ana Souza"
                                       Foreground="#9E8FC0" FontSize="11"
                                       FontFamily="Segoe UI" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="7,0" Style="{StaticResource CelulaTxt}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="8,5" Style="{StaticResource CelulaTxt}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="9,2" Style="{StaticResource CelulaTxt}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="8,2" Foreground="#A5D6A7"
                                   FontSize="14" FontWeight="Bold" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Border Grid.Column="5" Background="#1B5E20" CornerRadius="20"
                                Padding="10,4" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Aprovado" Foreground="#A5D6A7"
                                       FontSize="11" FontFamily="Segoe UI"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Linha 3 - Aprovado -->
                <Border Style="{StaticResource LinhaCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Engenharia de Software"
                                       Foreground="White" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"/>
                            <TextBlock Text="Prof. Marcos Freitas"
                                       Foreground="#9E8FC0" FontSize="11"
                                       FontFamily="Segoe UI" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="9,5" Style="{StaticResource CelulaTxt}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="9,0" Style="{StaticResource CelulaTxt}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="8,8" Style="{StaticResource CelulaTxt}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="9,1" Foreground="#A5D6A7"
                                   FontSize="14" FontWeight="Bold" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Border Grid.Column="5" Background="#1B5E20" CornerRadius="20"
                                Padding="10,4" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Aprovado" Foreground="#A5D6A7"
                                       FontSize="11" FontFamily="Segoe UI"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Linha 4 - Recuperação -->
                <Border Style="{StaticResource LinhaCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Banco de Dados"
                                       Foreground="White" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"/>
                            <TextBlock Text="Prof. Julia Mendes"
                                       Foreground="#9E8FC0" FontSize="11"
                                       FontFamily="Segoe UI" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="5,5" Style="{StaticResource CelulaTxt}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="6,0" Style="{StaticResource CelulaTxt}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="&#x2014;" Style="{StaticResource CelulaTxt}"
                                   HorizontalAlignment="Center" Opacity="0.4"/>
                        <TextBlock Grid.Column="4" Text="5,8" Foreground="#FFCC80"
                                   FontSize="14" FontWeight="Bold" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Border Grid.Column="5" Background="#4E3600" CornerRadius="20"
                                Padding="10,4" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Recupera&#xE7;&#xE3;o" Foreground="#FFCC80"
                                       FontSize="11" FontFamily="Segoe UI"/>
                        </Border>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
