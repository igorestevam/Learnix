<UserControl x:Class="Learnix.TelaMeusCursos"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Learnix"
             Background="#1E1E1E">

    <UserControl.Resources>

        <Style x:Key="CursoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#2A2040"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="22,18"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="BtnAcessarStyle" TargetType="Button">
            <Setter Property="Background" Value="#4E3A7A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#3A2860"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#2C1F4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnCertificadoStyle" TargetType="Button">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#1B5E20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSairStyle" TargetType="Button">
            <Setter Property="Background" Value="#7B1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#5C1010"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:SidebarControl x:Name="Sidebar" Grid.Column="0"/>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,32,36,32">

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="&#x1F4DA;  Meus Cursos"
                                   Foreground="White" FontSize="24" FontWeight="Bold"
                                   FontFamily="Segoe UI"/>
                        <TextBlock Text="Todas as suas matr&#xED;culas em um s&#xF3; lugar"
                                   Foreground="#9E8FC0" FontSize="12"
                                   FontFamily="Segoe UI" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>

                <Separator Background="#9E8FC0" Opacity="0.25" Margin="0,0,0,18"/>

                <Border x:Name="PainelVazio" Visibility="Collapsed"
                        Background="#2A2040" CornerRadius="12" Padding="40">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#x1F4DA;" FontSize="48"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="Voc&#xEA; ainda n&#xE3;o est&#xE1; matriculado em nenhum curso."
                                   Foreground="#9E8FC0" FontSize="14" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <ItemsControl x:Name="ListaCursos">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="16,0,0,0">

                                <Button Content="&#x27A1; Continuar para Avaliação" Background="#4E3A7A" Foreground="White"
                                        Padding="10,6" Margin="0,0,0,6" Click="BtnContinuarParaAvaliacao_Click" Tag="{Binding MatriculaId}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Percentual}" Value="100">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Content="&#x1F4DD; Fazer Avaliação" Background="#D84315" Foreground="White"
                                    Padding="10,6" Margin="0,0,0,6" Click="BtnAbrirAvaliacao_Click" Tag="{Binding CursoId}"
                                    Visibility="{Binding BotaoAvaliacaoVisivel}"/>

                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
        <Grid x:Name="PainelAvaliacaoAluno" Visibility="Collapsed" Background="#B3000000" Grid.RowSpan="10" Grid.ColumnSpan="10" Panel.ZIndex="100">
            <Border Background="#1E1E1E" CornerRadius="12" Padding="32"
                    HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="500" MaxWidth="700">
                <StackPanel>
                    <TextBlock Text="&#x1F4DD; AVALIAÇÃO FINAL DO CURSO" Foreground="White" FontSize="18" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,16"/>

                    <TextBlock x:Name="TxtPerguntaAluno1" Text="Carregando pergunta 1..." Foreground="#9E8FC0" FontSize="13" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtRespostaAluno1" Background="#3A2860" Foreground="White" BorderThickness="0" Padding="12,10" FontFamily="Segoe UI" FontSize="13" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,20"/>

                    <TextBlock x:Name="TxtPerguntaAluno2" Text="Carregando pergunta 2..." Foreground="#9E8FC0" FontSize="13" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtRespostaAluno2" Background="#3A2860" Foreground="White" BorderThickness="0" Padding="12,10" FontFamily="Segoe UI" FontSize="13" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,20"/>

                    <TextBlock x:Name="TxtPerguntaAluno3" Text="Carregando pergunta 3..." Foreground="#9E8FC0" FontSize="13" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtRespostaAluno3" Background="#3A2860" Foreground="White" BorderThickness="0" Padding="12,10" FontFamily="Segoe UI" FontSize="13" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,24"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Click="BtnCancelarAvaliacao_Click" Background="Transparent" Foreground="#D8CCF0" BorderThickness="0" Margin="0,0,16,0" Cursor="Hand" FontFamily="Segoe UI"/>
                        <Button Content="Enviar Respostas" Click="BtnEnviarAvaliacao_Click" Background="#2E7D32" Foreground="White" BorderThickness="0" Padding="16,8" Cursor="Hand" FontFamily="Segoe UI">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>