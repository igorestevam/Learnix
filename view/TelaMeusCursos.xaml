<UserControl x:Class="Learnix.TelaMeusCursos"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Learnix"
             Background="#1E1E1E">

    <UserControl.Resources>
        <Style x:Key="CursoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#2A2040"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="22,18"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="BtnAcessarStyle" TargetType="Button">
            <Setter Property="Background" Value="#4E3A7A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#3A2860"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#2C1F4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnCertificadoStyle" TargetType="Button">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#1B5E20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSairStyle" TargetType="Button">
            <Setter Property="Background" Value="#7B1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#5C1010"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:SidebarControl x:Name="Sidebar" Grid.Column="0"/>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,32,36,32">

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="&#x1F4DA;  Meus Cursos" Foreground="White" FontSize="24" FontWeight="Bold" FontFamily="Segoe UI"/>
                        <TextBlock Text="Todas as suas matr&#xED;culas em um s&#xF3; lugar" Foreground="#9E8FC0" FontSize="12" FontFamily="Segoe UI" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>

                <Separator Background="#9E8FC0" Opacity="0.25" Margin="0,0,0,18"/>

                <Border x:Name="PainelVazio" Visibility="Collapsed" Background="#2A2040" CornerRadius="12" Padding="40">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#x1F4DA;" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="Voc&#xEA; ainda n&#xE3;o est&#xE1; matriculado em nenhum curso." Foreground="#9E8FC0" FontSize="14" FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <ItemsControl x:Name="ListaCursos">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CursoCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <Border Background="{Binding CorCategoria}" CornerRadius="20" Padding="10,4" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding NomeCategoria}" Foreground="{Binding CorTextoCategoria}" FontFamily="Segoe UI" FontSize="11"/>
                                            </Border>
                                            <Border Background="#1B3A5E" CornerRadius="20" Padding="10,4">
                                                <TextBlock Text="{Binding CargaHoraria}" Foreground="#90CAF9" FontFamily="Segoe UI" FontSize="11"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding TituloCurso}" Foreground="White" FontSize="15" FontWeight="Bold" FontFamily="Segoe UI"/>
                                        <TextBlock Text="{Binding NomeInstrutor}" Foreground="#9E8FC0" FontSize="12" FontFamily="Segoe UI" Margin="0,4,0,0"/>

                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{Binding CorFundoBarra}" CornerRadius="3" Height="6" VerticalAlignment="Center">
                                                <Border Background="{Binding CorBarra}" CornerRadius="3" HorizontalAlignment="Left" Width="{Binding LarguraBarra}"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding PercentualTexto}" Foreground="{Binding CorTextoProgresso}" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                                        <TextBlock Text="{Binding TextoStatusMsg}" Foreground="{Binding CorTextoStatus}" 
                                                   Visibility="{Binding TextoStatusVisivel}" FontFamily="Segoe UI" FontSize="13" 
                                                   FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0"/>

                                        <Button Content="&#x1F4DA; Acessar" Style="{StaticResource BtnAcessarStyle}" 
                                                Click="BtnAcessar_Click" Tag="{Binding MatriculaId}" Margin="0,0,6,0"
                                                Visibility="{Binding BotaoAcessarVisivel}" />

                                        <Button Content="&#x1F4DD; Avaliação" Background="#D84315" Foreground="White" BorderThickness="0" Padding="12,6" FontSize="12" FontFamily="Segoe UI" Cursor="Hand" Margin="0,0,6,0"
                                                Click="BtnAbrirAvaliacao_Click" Tag="{Binding MatriculaId}" 
                                                Visibility="{Binding BotaoAvaliacaoVisivel}">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>

                                        <Button Content="&#x1F3C6; Certificado" Style="{StaticResource BtnCertificadoStyle}" 
                                                Click="BtnCertificado_Click" Tag="{Binding MatriculaId}" Margin="0,0,6,0"
                                                Visibility="{Binding BotaoCertificadoVisivel}" />

                                        <Button Content="&#x1F6AA; Sair do Curso" Style="{StaticResource BtnSairStyle}" 
                                                Click="BtnSairCurso_Click" Tag="{Binding MatriculaId}"
                                                Visibility="{Binding BotaoSairVisivel}" />

                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <Grid x:Name="PainelAvaliacaoAluno" Visibility="Collapsed" Background="#B3000000" Grid.RowSpan="10" Grid.ColumnSpan="10" Panel.ZIndex="100">
            <Border Background="#1E1E1E" CornerRadius="12" Padding="32"
                    HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="500" MaxWidth="700">
                <StackPanel>
                    <TextBlock Text="&#x1F4DD; AVALIAÇÃO FINAL DO CURSO" Foreground="White" FontSize="18" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,16"/>

                    <TextBlock x:Name="TxtPerguntaAluno1" Text="Carregando pergunta 1..." Foreground="#9E8FC0" FontSize="13" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtRespostaAluno1" Background="#3A2860" Foreground="White" BorderThickness="0" Padding="12,10" FontFamily="Segoe UI" FontSize="13" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,20"/>

                    <TextBlock x:Name="TxtPerguntaAluno2" Text="Carregando pergunta 2..." Foreground="#9E8FC0" FontSize="13" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtRespostaAluno2" Background="#3A2860" Foreground="White" BorderThickness="0" Padding="12,10" FontFamily="Segoe UI" FontSize="13" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,20"/>

                    <TextBlock x:Name="TxtPerguntaAluno3" Text="Carregando pergunta 3..." Foreground="#9E8FC0" FontSize="13" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtRespostaAluno3" Background="#3A2860" Foreground="White" BorderThickness="0" Padding="12,10" FontFamily="Segoe UI" FontSize="13" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,24"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Click="BtnCancelarAvaliacao_Click" Background="Transparent" Foreground="#D8CCF0" BorderThickness="0" Margin="0,0,16,0" Cursor="Hand" FontFamily="Segoe UI"/>
                        <Button Content="Enviar Respostas" Click="BtnEnviarAvaliacao_Click" Background="#2E7D32" Foreground="White" BorderThickness="0" Padding="16,8" Cursor="Hand" FontFamily="Segoe UI">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>