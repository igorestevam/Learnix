<UserControl x:Class="Learnix.TelaMeusCursos"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Learnix"
             Background="#1E1E1E">

    <UserControl.Resources>

        <Style x:Key="CursoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#2A2040"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="22,18"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="BtnAcessarStyle" TargetType="Button">
            <Setter Property="Background" Value="#4E3A7A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#3A2860"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#2C1F4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnCertificadoStyle" TargetType="Button">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#1B5E20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSairStyle" TargetType="Button">
            <Setter Property="Background" Value="#7B1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borda" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borda" Property="Background" Value="#5C1010"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:SidebarControl x:Name="Sidebar" Grid.Column="0"/>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,32,36,32">

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="&#x1F4DA;  Meus Cursos"
                                   Foreground="White" FontSize="24" FontWeight="Bold"
                                   FontFamily="Segoe UI"/>
                        <TextBlock Text="Todas as suas matr&#xED;culas em um s&#xF3; lugar"
                                   Foreground="#9E8FC0" FontSize="12"
                                   FontFamily="Segoe UI" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>

                <Separator Background="#9E8FC0" Opacity="0.25" Margin="0,0,0,18"/>

                <Border x:Name="PainelVazio" Visibility="Collapsed"
                        Background="#2A2040" CornerRadius="12" Padding="40">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#x1F4DA;" FontSize="48"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="Voc&#xEA; ainda n&#xE3;o est&#xE1; matriculado em nenhum curso."
                                   Foreground="#9E8FC0" FontSize="14" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <ItemsControl x:Name="ListaCursos">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CursoCardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding TituloCurso}"
                                                       Foreground="White" FontSize="15" FontWeight="Bold"
                                                       FontFamily="Segoe UI"/>
                                            <TextBlock Text="{Binding NomeInstrutor}"
                                                       Foreground="#9E8FC0" FontSize="12"
                                                       FontFamily="Segoe UI" Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <Border Grid.Column="1" Background="{Binding CorCategoria}"
                                                CornerRadius="20" Padding="12,5"
                                                VerticalAlignment="Top" Margin="12,0">
                                            <TextBlock Text="{Binding NomeCategoria}"
                                                       Foreground="{Binding CorTextoCategoria}"
                                                       FontFamily="Segoe UI" FontSize="11"/>
                                        </Border>

                                        <!-- Botões -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Top">
                                            <Button Content="&#x25B6; Acessar"
                                                    Style="{StaticResource BtnAcessarStyle}"
                                                    Margin="0,0,8,0"
                                                    Click="BtnAcessar_Click"
                                                    Tag="{Binding MatriculaId}"/>
                                            <Button Content="&#x1F3C6; Certificado"
                                                    Style="{StaticResource BtnCertificadoStyle}"
                                                    Visibility="{Binding BotaoCertificadoVisivel}"
                                                    Margin="0,0,8,0"
                                                    Click="BtnCertificado_Click"
                                                    Tag="{Binding MatriculaId}"/>
                                            <Button Content="&#x1F6AA; Sair"
                                                    Style="{StaticResource BtnSairStyle}"
                                                    Visibility="{Binding BotaoSairVisivel}"
                                                    Click="BtnSairCurso_Click"
                                                    Tag="{Binding MatriculaId}"/>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,10">
                                        <TextBlock Text="{Binding DataFormatada}" Foreground="#9E8FC0"
                                                   FontSize="12" FontFamily="Segoe UI" Margin="0,0,18,0"/>
                                        <TextBlock Text="{Binding CargaHoraria}" Foreground="#9E8FC0"
                                                   FontSize="12" FontFamily="Segoe UI" Margin="0,0,18,0"/>
                                        <TextBlock Text="{Binding NumAulas}" Foreground="#9E8FC0"
                                                   FontSize="12" FontFamily="Segoe UI"/>
                                    </StackPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="{Binding CorFundoBarra}"
                                                CornerRadius="3" Height="6" VerticalAlignment="Center">
                                            <Border Background="{Binding CorBarra}" CornerRadius="3"
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding LarguraBarra}"/>
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding PercentualTexto}"
                                                   Foreground="{Binding CorTextoProgresso}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   FontFamily="Segoe UI" Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>